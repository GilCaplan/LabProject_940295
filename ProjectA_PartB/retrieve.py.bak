#!/usr/bin/env python3
"""
retrieve.py — Query-time retrieval with three-path fusion.

Three retrieval paths, fused via Weighted Reciprocal Rank Fusion:

  Path 1 — Dense ANN (weight 1.0)
    Embed the raw query, search FAISS for top-K nearest chunks.

  Path 2 — BM25 sparse (weight 4.0)
    Tokenise the query, score chunks using prebuilt BM25 index.
    Outperforms dense on this fictional corpus (23 vs 16 hits).

  Path 3 — HyDE (weight 1.0 each, 3 hypotheses)
    Embed 3 hypothetical answer sentences per query.
    All texts embedded in one batched GPU forward pass.

All queries + HyDE hypotheses embedded in a single batched forward pass.
"""

import re
import math
from collections import defaultdict

import numpy as np
import faiss

from embed import embed_queries

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
FAISS_TOP_K  = 200
BM25_TOP_K   = 200
RRF_K        = 60
FINAL_TOP_N  = 10
N_HYDE       = 3       # number of HyDE hypotheses per query
BM25_WEIGHT  = 4.0     # BM25 outperforms dense on fictional corpus
BM25_DF_FRAC = 0.05    # skip terms appearing in >5% of chunks

_HYDE_TEMPLATES = [
    "This Wikipedia article answers the query '{query}'. It discusses the relevant facts, background, and key details.",
    "A Wikipedia page about {query} would describe the specific person, place, event, or concept involved.",
    "The answer to '{query}' can be found in a Wikipedia article covering the topic in detail.",
]

# ---------------------------------------------------------------------------
# Singleton index store
# ---------------------------------------------------------------------------
class _IndexStore:
    faiss_index:   faiss.Index | None = None
    chunk_meta:    list[dict]  | None = None
    bm25_inverted: dict        | None = None
    bm25_stats:    dict        | None = None

_store = _IndexStore()


def load_indexes(faiss_path, meta_path, bm25_inv_path, bm25_stats_path, nprobe=32):
    """Load all prebuilt indexes. No-op if already loaded."""
    if _store.faiss_index is not None:
        return
    from index import load_faiss_index, load_chunk_meta, load_bm25_index
    print("Loading indexes ...")
    _store.faiss_index   = load_faiss_index(faiss_path, nprobe=nprobe)
    _store.chunk_meta    = load_chunk_meta(meta_path)
    _store.bm25_inverted, _store.bm25_stats = load_bm25_index(bm25_inv_path, bm25_stats_path)
    print("Indexes loaded.")


# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# Minimal Porter stemmer — pure Python, no dependencies
# Based on the original Porter (1980) algorithm
# ---------------------------------------------------------------------------
class _PorterStemmer:
    def __init__(self):
        self._vowels = set("aeiou")

    def _cons(self, word, i):
        if word[i] in self._vowels:
            return False
        if word[i] == "y":
            return i == 0 or not self._cons(word, i - 1)
        return True

    def _m(self, word):
        """Count VC sequences in stem."""
        n, i, max_i = 0, 0, len(word)
        while i < max_i:
            if not self._cons(word, i):
                break
            i += 1
        while i < max_i:
            while i < max_i and not self._cons(word, i):
                i += 1
            while i < max_i and self._cons(word, i):
                i += 1
            n += 1
        return n

    def _has_vowel(self, word):
        return any(not self._cons(word, i) for i in range(len(word)))

    def _ends(self, word, s):
        return word.endswith(s)

    def _setto(self, word, stem, s):
        return stem + s

    def stem(self, word):
        if len(word) <= 2:
            return word
        w = word.lower()
        # Step 1a
        if w.endswith("sses"):    w = w[:-2]
        elif w.endswith("ies"):   w = w[:-2]
        elif w.endswith("ss"):    pass
        elif w.endswith("s"):     w = w[:-1]
        # Step 1b
        if w.endswith("eed"):
            if self._m(w[:-3]) > 0: w = w[:-1]
        elif w.endswith("ed"):
            stem = w[:-2]
            if self._has_vowel(stem):
                w = stem
                if w.endswith("at") or w.endswith("bl") or w.endswith("iz"):
                    w += "e"
                elif len(w) > 1 and self._cons(w,-1) and self._cons(w,-2) and w[-1]==w[-2] and w[-1] not in "lsz":
                    w = w[:-1]
        elif w.endswith("ing"):
            stem = w[:-3]
            if self._has_vowel(stem):
                w = stem
                if w.endswith("at") or w.endswith("bl") or w.endswith("iz"):
                    w += "e"
                elif len(w) > 1 and self._cons(w,-1) and self._cons(w,-2) and w[-1]==w[-2] and w[-1] not in "lsz":
                    w = w[:-1]
        # Step 1c
        if w.endswith("y") and len(w) > 1 and self._has_vowel(w[:-1]):
            w = w[:-1] + "i"
        # Step 2
        step2 = [
            ("ational","ate"),("tional","tion"),("enci","ence"),("anci","ance"),
            ("izer","ize"),("bli","ble"),("alli","al"),("entli","ent"),
            ("eli","e"),("ousli","ous"),("ization","ize"),("ation","ate"),
            ("ator","ate"),("alism","al"),("iveness","ive"),("fulness","ful"),
            ("ousness","ous"),("aliti","al"),("iviti","ive"),("biliti","ble"),
        ]
        for suf, rep in step2:
            if w.endswith(suf) and self._m(w[:-len(suf)]) > 0:
                w = w[:-len(suf)] + rep; break
        # Step 3
        step3 = [
            ("icate","ic"),("ative",""),("alize","al"),("iciti","ic"),
            ("ical","ic"),("ful",""),("ness",""),
        ]
        for suf, rep in step3:
            if w.endswith(suf) and self._m(w[:-len(suf)]) > 0:
                w = w[:-len(suf)] + rep; break
        # Step 4
        step4 = [
            "al","ance","ence","er","ic","able","ible","ant","ement",
            "ment","ent","ion","ou","ism","ate","iti","ous","ive","ize",
        ]
        for suf in step4:
            stem = w[:-len(suf)]
            if w.endswith(suf) and self._m(stem) > 1:
                if suf == "ion" and stem and stem[-1] in "st":
                    w = stem
                elif suf != "ion":
                    w = stem
                break
        # Step 5a
        if w.endswith("e"):
            stem = w[:-1]
            if self._m(stem) > 1:
                w = stem
            elif self._m(stem) == 1:
                w = stem
        # Step 5b
        if len(w) > 1 and w[-1] == w[-2] == "l" and self._cons(w,-1) and self._m(w) > 1:
            w = w[:-1]
        return w

_stemmer = _PorterStemmer()

def _expand_decades(t: str) -> list[str]:
    """Expand decade tokens: '1820s' -> ['1820',...,'1829']"""
    m = re.match(r"(\d{3})0s", t)
    if m:
        base = int(m.group(1)) * 10
        return [str(base + i) for i in range(10)]
    m = re.match(r"(\d{2})(\d{2})s", t)
    if m:
        base = int(m.group(1) + m.group(2))
        return [str(base + i) for i in range(10)]
    return [t]


def _bm25_tokenize(text: str) -> list[str]:
    """
    Mirror of index-time tokenizer: stemmed unigrams + bigrams + decade expansion.
    - Stemming fixes paraphrase gap ('captained' -> 'captain')
    - Decades: '1820s' -> 1820..1829 (matches '1826' in corpus)
    - Bigrams: phrase matching
    """
    text = text.lower()
    text = re.sub(r"[^a-z0-9\s]", " ", text)
    raw_tokens = text.split()

    # Expand decades first
    expanded = []
    for t in raw_tokens:
        expanded.extend(_expand_decades(t))

    # Stem + keep original
    tokens = []
    for t in expanded:
        stemmed = _stemmer.stem(t)
        tokens.append(stemmed)
        if stemmed != t:
            tokens.append(t)

    # Bigrams on stemmed tokens
    bigrams = [f"{a}_{b}" for a, b in zip(tokens, tokens[1:])]

    # Boost numbers and long words
    boosted = [t for t in expanded if re.match(r"\d+", t) or len(t) > 6]

    return tokens + bigrams + boosted


def _dense_retrieve(vecs: np.ndarray) -> list[list[tuple[int, float]]]:
    """Batch FAISS search. Returns list of (chunk_id, score) per query."""
    scores_mat, ids_mat = _store.faiss_index.search(vecs, FAISS_TOP_K)
    results = []
    for scores_row, ids_row in zip(scores_mat, ids_mat):
        hits = [(int(cid), float(s)) for s, cid in zip(scores_row, ids_row) if cid >= 0]
        results.append(hits)
    return results


def _bm25_retrieve(tokens: list[str]) -> list[tuple[int, float]]:
    """Score chunks via BM25, skipping high-df terms."""
    inverted = _store.bm25_inverted
    N = _store.bm25_stats["N"]
    max_df = int(N * BM25_DF_FRAC)
    acc: dict[int, float] = defaultdict(float)
    for token in set(tokens):
        if token not in inverted:
            continue
        postings = inverted[token]
        if len(postings) > max_df:
            continue
        for cid_str, score in postings.items():
            acc[int(cid_str)] += score
    ranked = sorted(acc.items(), key=lambda x: x[1], reverse=True)
    return ranked[:BM25_TOP_K]


def _rrf_fuse(ranked_lists, weights=None) -> dict[int, float]:
    """Weighted Reciprocal Rank Fusion."""
    if weights is None:
        weights = [1.0] * len(ranked_lists)
    scores: dict[int, float] = defaultdict(float)
    for ranked, w in zip(ranked_lists, weights):
        for rank, (cid, _) in enumerate(ranked):
            scores[cid] += w / (RRF_K + rank + 1)
    return scores


def _chunk_scores_to_page_scores(chunk_scores: dict[int, float]) -> list[tuple[int, float]]:
    """Max-pool chunk scores to page scores. Summary chunks get 1.5x boost."""
    meta = _store.chunk_meta
    page_scores: dict[int, float] = defaultdict(float)
    for cid, score in chunk_scores.items():
        if cid >= len(meta):
            continue
        m = meta[cid]
        boosted = score * (1.5 if m["chunk_type"] == "summary" else 1.0)
        pid = int(m["page_id"])
        if boosted > page_scores[pid]:
            page_scores[pid] = boosted
    return sorted(page_scores.items(), key=lambda x: x[1], reverse=True)


# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

def retrieve_batch(queries: list[str]) -> list[list[int]]:
    """
    Retrieve top-10 page IDs for each query.
    All embeddings done in one batched GPU forward pass.
    """
    Q = len(queries)

    # Build HyDE texts
    hyde_texts = []
    for q in queries:
        for tmpl in _HYDE_TEMPLATES:
            hyde_texts.append(tmpl.format(query=q))

    # Single batched embed: queries + all HyDE texts
    all_vecs = embed_queries(list(queries) + hyde_texts)  # (Q + Q*N_HYDE, 384)
    query_vecs = all_vecs[:Q]                              # (Q, 384)
    hyde_vecs  = all_vecs[Q:].reshape(Q, N_HYDE, -1)      # (Q, N_HYDE, 384)

    # Batch dense search for queries
    dense_results = _dense_retrieve(query_vecs)

    all_page_results = []
    for i, query in enumerate(queries):
        dense_hits  = dense_results[i]
        sparse_hits = _bm25_retrieve(_bm25_tokenize(query))

        # HyDE: search each hypothesis
        hyde_hit_lists = []
        for h in range(N_HYDE):
            h_results = _dense_retrieve(hyde_vecs[i, h:h+1, :])
            hyde_hit_lists.append(h_results[0])

        # Weighted RRF: dense=1, bm25=4, each hyde=1
        all_lists   = [dense_hits, sparse_hits] + hyde_hit_lists
        all_weights = [1.0, BM25_WEIGHT] + [1.0] * N_HYDE
        chunk_scores = _rrf_fuse(all_lists, all_weights)

        page_ranked = _chunk_scores_to_page_scores(chunk_scores)
        top_pages   = [int(pid) for pid, _ in page_ranked[:FINAL_TOP_N]]
        all_page_results.append(top_pages)

    return all_page_results